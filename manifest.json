{
  "manifest_version": 3,
  "name": "Green Timer & Stopwatch",
  "version": "1.6",
  "description": "A sleek #00ff00 themed timer and stopwatch extension with LeetCode auto-detection and stats.",
  "permissions": ["notifications", "alarms", "storage", "activeTab"],
  "host_permissions": ["*://*.leetcode.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.leetcode.com/problems/*"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "toggle-timer": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Toggle the first active problem timer"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "greentimer@nxorg",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
